rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Business upgrade requests - users can create, admins can read all
    match /businessUpgradeRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, write: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Businesses collection - business owners can manage their own data
    match /businesses/{businessId} {
      allow read, write: if request.auth != null && 
        (resource.data.ownerId == request.auth.uid || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Gift cards - business owners can manage their own cards, customers can read
    match /giftCards/{cardId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (resource.data.businessId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessProfile.businessId || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Orders - users can read their own orders, business owners can read their business orders
    match /orders/{orderId} {
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         resource.data.businessId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessProfile.businessId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null;
    }
  }
} 